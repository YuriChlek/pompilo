# PostgreSQL host name or IP address.
DB_HOST=localhost
# PostgreSQL port for the local database connection.
DB_PORT=5432
# PostgreSQL database name used by the bot.
DATABASE=pompilo_db
# PostgreSQL user name.
DB_USER=admin
# PostgreSQL password.
DB_PASSWORD=admin_pass
# Connection timeout for PostgreSQL pool creation in seconds.
DB_CONNECT_TIMEOUT=5

# Bybit API key for authenticated trading requests.
BYBIT_API_KEY=LaaXnBP9CVS62keBjG
# Bybit API secret for signing authenticated requests.
BYBIT_API_SECRET=VamwPNU3dDFUYcwtLkSbzat7Q1jLgpEDWKgl
# Bybit trading REST API endpoint for order execution.
BYBIT_TRADING_API_ENDPOINT=https://api-demo.bybit.com
# Bybit futures market REST API endpoint for ticker and instrument info.
BYBIT_FUTURES_MARKET_API_ENDPOINT=https://api-demo.bybit.com
# Bybit market data REST API endpoint for spot order book bootstrap.
BYBIT_MARKET_DATA_API_ENDPOINT=https://api.bybit.com
# Bybit public WebSocket endpoint for spot market data.
BYBIT_MARKET_DATA_WS_ENDPOINT=wss://stream.bybit.com/v5/public/spot
# Bybit private WebSocket endpoint for order, execution and position updates.
BYBIT_PRIVATE_WS_ENDPOINT=wss://stream.bybit.com/v5/private?max_active_time=10m
# Bybit receive window in milliseconds for signed requests.
BYBIT_RECV_WINDOW=10000

# Telegram bot token used for notifications.
TOKEN=7962265207:AAHL2b0TC-Quj5u5Xz3-Bm2sSf-0qlcbAiQ
# Telegram chat or channel ID that receives notifications.
CHAT_ID=-4954272566
# Application timezone for logs and Telegram messages.
APP_TIMEZONE=Europe/Kyiv

# Preferred exchange used as the default analysis reference book.
ORDERFLOW_ANALYSIS_REFERENCE_EXCHANGE=bybit
# Exchanges observed for spot order book and tape data.
ORDERFLOW_OBSERVATION_EXCHANGES=bybit,binance,okx
# Symbols traded by the bot.
ORDERFLOW_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,DOGEUSDT,XRPUSDT,SUIUSDT
# Maximum number of order book levels retained per snapshot.
ORDERFLOW_BOOK_DEPTH=20
# Number of historical book snapshots stored per symbol and exchange.
ORDERFLOW_BOOK_HISTORY_SIZE=32
# Tape aggregation window in milliseconds.
ORDERFLOW_TAPE_WINDOW_MS=3000
# Order book history lookback window used for wall analysis in milliseconds.
ORDERFLOW_WALL_LOOKBACK_MS=1500

# Maximum allowed wall distance from market in basis points.
ORDERFLOW_MAX_WALL_DISTANCE_BPS=8
# Maximum allowed wall distance from market in ticks.
ORDERFLOW_MAX_WALL_DISTANCE_TICKS=8
# Minimum wall notional value in USDT.
ORDERFLOW_MIN_WALL_NOTIONAL_USDT=250000
# Minimum wall size relative to surrounding liquidity.
ORDERFLOW_MIN_WALL_RELATIVE_SIZE=4.0
# Minimum time a wall must persist to be considered valid in milliseconds.
ORDERFLOW_MIN_WALL_PERSIST_MS=800
# Maximum allowed wall size drop percentage before pull/spoof suspicion.
ORDERFLOW_MAX_WALL_SIZE_DROP_PCT=0.45
# Minimum wall quality score required for signal generation.
ORDERFLOW_MIN_WALL_SCORE=65
# Maximum number of pull events tolerated before rejecting a wall.
ORDERFLOW_MAX_PULL_EVENTS=3
# Maximum number of chase ticks tolerated before rejecting a wall.
ORDERFLOW_MAX_CHASE_TICKS=2
# Maximum spoof risk score tolerated.
ORDERFLOW_MAX_SPOOF_SCORE=45
# Minimum number of wall tests required.
ORDERFLOW_MIN_TEST_COUNT=2
# Maximum distance in ticks to count a wall touch as a test.
ORDERFLOW_TEST_TOUCH_TICKS=2
# Minimum debounce time between wall test counts in milliseconds.
ORDERFLOW_TEST_DEBOUNCE_MS=500
# Minimum rejection distance from a wall in ticks.
ORDERFLOW_MIN_REJECTION_TICKS=1
# Minimum retained ratio / defended ratio required for a wall.
ORDERFLOW_MIN_DEFENDED_RATIO=0.55
# Minimum tape pressure ratio required to confirm long/short setups.
ORDERFLOW_MIN_TAPE_PRESSURE_RATIO=1.15
# Maximum cross-exchange price deviation in basis points for confirmation.
ORDERFLOW_CROSS_CONFIRMATION_BPS=6
# Minimum number of cross-exchange confirmations required.
ORDERFLOW_MIN_CROSS_EXCHANGE_CONFIRMATIONS=1
# Maximum allowed age of the reference book in milliseconds.
ORDERFLOW_BOOK_STALE_MS=2500
# Fixed stop-loss distance as a percent of entry price.
STOP_LOSS_SIZE=0.5
# Maximum allowed spread in ticks for a valid setup.
ORDERFLOW_MAX_SPREAD_TICKS=3
# Maximum allowed basis between spot and futures in basis points.
ORDERFLOW_MAX_BASIS_BPS=50
# Entry offset from detected wall in ticks.
ORDERFLOW_ENTRY_OFFSET_TICKS=1
# Invalidation offset from detected wall in ticks.
ORDERFLOW_INVALIDATION_OFFSET_TICKS=1
# Legacy stop offset in ticks kept for compatibility with config shape.
ORDERFLOW_STOP_OFFSET_TICKS=1
# Take-profit target expressed as R multiple of stop distance.
ORDERFLOW_TAKE_PROFIT_R_MULTIPLE=1.5
# Allowed tolerance in ticks when checking whether a pending wall is still active.
ORDERFLOW_PENDING_WALL_TOLERANCE_TICKS=2
# Maximum age of a pending entry order in seconds.
ORDERFLOW_PENDING_ORDER_MAX_AGE_SECONDS=30
# Distance in ticks required before moving stop to breakeven.
ORDERFLOW_BREAKEVEN_ARM_TICKS=3
# Extra breakeven buffer in ticks after arm condition is reached.
ORDERFLOW_BREAKEVEN_BUFFER_TICKS=1

# Risk per trade as a percent of account equity.
ORDERFLOW_RISK_PER_TRADE_PCT=0.15
# Maximum allowed daily loss as a percent of account equity.
ORDERFLOW_MAX_DAILY_LOSS_PCT=1.5
# Maximum number of trades allowed per day.
ORDERFLOW_MAX_TRADES_PER_DAY=30
# Maximum consecutive losing trades allowed before blocking new entries.
ORDERFLOW_MAX_CONSECUTIVE_LOSSES=5
# Cooldown time after a completed trade or invalidation in seconds.
ORDERFLOW_SYMBOL_COOLDOWN_SECONDS=120
