# PostgreSQL host for candle/state storage.
DB_HOST=localhost
# PostgreSQL port.
DB_PORT=5432
# PostgreSQL database name.
DATABASE=pompilo_db
# PostgreSQL user.
DB_USER=admin
# PostgreSQL password.
DB_PASSWORD=admin_pass

# Bybit API key for demo/real environment.
BYBIT_API_KEY=cyoVezNy2I9s5Q1fgW
# Bybit API secret for demo/real environment.
BYBIT_API_SECRET=KDPUTSOlbOZiUx5drq9H1fICOBOcEmOj56zJ
# Bybit receive window in milliseconds.
BYBIT_RECV_WINDOW=10000
# Execution mode: paper, bybit_spot_demo, bybit_spot_live.
EXECUTION_MODE=bybit_spot_demo

# Comma-separated trading symbols for the bot.
SPOT_TRADING_SYMBOLS=ETHUSDT
# Candle lookback used by planner analysis.
CANDLE_LOOKBACK=2400
# Max number of newly created orders in one sync cycle.
MAX_NEW_ORDERS_PER_CYCLE=5

# Minimum symbol-level entry budget in quote currency.
MIN_SYMBOL_ENTRY_NOTIONAL=25
# Max symbol inventory as % of total equity.
MAX_SYMBOL_INVENTORY_PCT_OF_EQUITY=0.08
# Max new-entry budget per symbol as % of free quote.
MAX_SYMBOL_NEW_ENTRY_PCT_OF_FREE_QUOTE=0.10

# Enable trigger-based underwater averaging mode.
UNDERWATER_AVERAGING_ENABLED=true
# Minimum drawdown vs cost basis required to activate underwater averaging.
UNDERWATER_AVERAGING_TRIGGER_PCT=0.10
# Fraction of symbol entry budget reserved for underwater averaging.
UNDERWATER_RECOVERY_BUDGET_PCT=0.25
# Recovery-budget multiplier used when regime is RANGE.
UNDERWATER_RANGE_BUDGET_MULTIPLIER=0.50
# Recovery-budget multiplier used when regime is UPTREND.
UNDERWATER_UPTREND_BUDGET_MULTIPLIER=1.00
# Max number of recovery buy levels while averaging underwater.
UNDERWATER_MAX_RECOVERY_LEVELS=5
# Drawdown vs cost basis after which underwater averaging is disabled again.
UNDERWATER_DEEP_STOP_PCT=0.25

# Scheduler target minute in every hour.
RUN_TARGET_MINUTE=0
# Scheduler target second in every hour.
RUN_TARGET_SECOND=1

# Telegram bot token for notifications.
TOKEN=7962265207:AAHL2b0TC-Quj5u5Xz3-Bm2sSf-0qlcbAiQ
# Telegram chat id for notifications.
CHAT_ID=-4734898285
# Application timezone for scheduler/logging context.
APP_TIMEZONE=Europe/Kyiv
